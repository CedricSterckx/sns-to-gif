{
  "name": "sns-to-gif",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun --cwd packages/backend --watch src/index.ts\" \"npm run dev -w packages/frontend\"",
    "build": "npm run build -w packages/frontend",
    "start": "bun packages/backend/src/index.ts"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
